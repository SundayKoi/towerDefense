# ─── Capacitor / iOS ───
# The ios/ directory is generated by `npx cap add ios` on a Mac. We keep the
# Capacitor config + any custom native source checked in, but NOT the
# CocoaPods-managed Pods/ folder (huge, platform-specific) or per-user Xcode
# state (signing IDs / team-specific paths leak otherwise).
ios/App/Pods/
ios/App/Podfile.lock
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/DerivedData/
ios/App/output/

# Capacitor runtime artifacts
.cap-cache/

# itch.io upload artifact — regenerated on demand via `npm run itch`.
# Large enough to bloat the repo if committed by accident.
netrunner-itch.zip
